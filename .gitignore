# === Secrets (NEVER commit — public repo) ===
.env
.env.local
.env.*.local
*.pem

# Claude Code local config (per-machine: permission grants, local paths)
.claude/settings.local.json
# Claude Code per-machine agent state (memory, session projects) — never commit
.claude/projects/
# NOTE: .mcp.json is intentionally TRACKED (committed) — it holds only ${...} env
# expansions + a non-secret project_ref. Do NOT add literal tokens to it.

# === Dependencies ===
/node_modules
/.pnp
.pnp.*
.yarn/*

# === Next.js build / cache ===
/.next/
/out/
/build
next-env.d.ts

# === Vercel ===
.vercel

# === Supabase (local stack) ===
/supabase/.branches
/supabase/.temp
