# === WebComms & Pay — environment template ===
# Copy to .env.local (gitignored) and fill in. NEVER commit real values — this is a PUBLIC repo.

# --- Supabase (app) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Resend ---
RESEND_API_KEY=

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- App ---
NEXT_PUBLIC_APP_URL=

# === MCP servers (.mcp.json) — used by Claude Code, expanded via ${...} ===
# Supabase MCP (read-only DB introspection)
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
# GitHub MCP
GITHUB_PERSONAL_ACCESS_TOKEN=
